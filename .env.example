# ----- Service runtime -----
PORT=8080
LOG_LEVEL=INFO
# ENVIRONMENT: one of local | dev | staging | prod
ENVIRONMENT=local

# ----- Data stores -----
DATABASE_URL=postgresql+psycopg://saaf:saaf@localhost:5432/saaf
S3_BUCKET=saaf-loan-docs-local

# ----- LLM provider -----
# LLM_PROVIDER: one of anthropic | bedrock | mock
# If neither ANTHROPIC_API_KEY nor Bedrock creds are set, the LLM call
# falls back to a deterministic mock so the service still boots.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Bedrock alternative: AWS creds picked up from the standard chain
AWS_REGION=us-east-1

# ----- Outbound email (borrower communications) -----
SES_FROM_ADDRESS=loans@saaffinance.com

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=underwriting-agent
